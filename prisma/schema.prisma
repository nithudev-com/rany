generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  BACKORDER
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Product {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  sku              String        @unique
  barcode          String?
  title            String
  slug             String        @unique
  shortDescription String?
  description      String?
  status           ProductStatus @default(ACTIVE)
  basePrice        Float
  salePrice        Float?
  stockStatus      StockStatus   @default(IN_STOCK)
  stockQuantity    Int           @default(0)
  lowStockLimit    Int?
  mainImage        String?
  videoUrl         String?
  seoTitle         String?
  seoDescription   String?
  canonicalUrl     String?
  faq              Json?
  details          Json?
  saleStartDate    DateTime?
  saleEndDate      DateTime?
  weight           Float?
  length           Float?
  width            Float?
  height           Float?
  shippingInfo     Json?
  returnInfo       String?
  warrantyInfo     String?
  isFeatured       Boolean       @default(false)

  // AI Product Manager Fields
  productType       String?
  focusKeyword      String?
  secondaryKeywords Json?
  ogTitle           String?
  ogDescription     String?
  readinessScore    Int     @default(0)
  validationStatus  String?
  generatedByAI     Boolean @default(false)
  benefits          Json?
  features          Json?
  specifications    Json?
  tags              Json?

  categoryId    String?  @db.ObjectId
  brandId       String?  @db.ObjectId
  importBatchId String?  @db.ObjectId
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category        Category?           @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  brand           Brand?              @relation(fields: [brandId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  importBatch     ProductImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  variants        ProductVariant[]
  images          ProductImage[]
  reviews         Review[]
  wishlistedItems WishlistItem[]
  blogs           BlogPost[]          @relation("ProductToBlog")

  @@index([status])
  @@index([categoryId, status])
  @@index([brandId, status])
  @@index([updatedAt])
}

model ProductVariant {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  productId     String      @db.ObjectId
  sku           String      @unique
  barcode       String?
  price         Float
  salePrice     Float?
  stockQuantity Int         @default(0)
  stockStatus   StockStatus @default(IN_STOCK)
  image         String?
  isEnabled     Boolean     @default(true)
  attributes    Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([productId])
  @@index([price])
  @@index([stockStatus])
}

model Category {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  slug           String   @unique
  image          String?
  parentId       String?  @db.ObjectId
  seoTitle       String?
  seoDescription String?
  showOnHome     Boolean  @default(false)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId])
}

model Brand {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  slug           String   @unique
  logo           String?
  seoTitle       String?
  seoDescription String?
  showOnHome     Boolean  @default(true)
  faqs           Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  products Product[]
}

model ProductImage {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  productId String  @db.ObjectId
  imageUrl  String
  publicId  String?
  width     Int?
  height    Int?
  format    String?
  bytes     Int?
  altText   String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([productId, sortOrder])
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  productId String   @db.ObjectId
  rating    Int
  title     String?
  body      String?
  author    String?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([productId, approved])
}

model ProductImportBatch {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  filename    String?
  status      ImportStatus @default(PENDING)
  updateMode  String       @default("FULL") // "FULL" or "PRICE_STOCK_ONLY"
  totalRows   Int          @default(0)
  successRows Int          @default(0)
  failedRows  Int          @default(0)
  message     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  rows     ProductImportRow[]
  products Product[]
}

model ProductImportRow {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  batchId        String    @db.ObjectId
  rowNumber      Int
  sku            String?
  barcode        String?
  variantImage   String?
  title          String?
  slug           String?
  categorySlug   String?
  categoryName   String?
  brandSlug      String?
  brandName      String?
  price          Float?
  salePrice      Float?
  stockQuantity  Int?
  imageUrl       String?
  seoTitle       String?
  seoDescription String?
  rawData        Json?
  errorMessage   String?
  processedAt    DateTime?
  createdAt      DateTime  @default(now())

  batch ProductImportBatch @relation(fields: [batchId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([batchId])
  @@index([batchId, errorMessage])
  @@index([sku])
}

model Currency {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  code         String   @unique
  name         String
  symbol       String
  exchangeRate Float    @default(1.0000)
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  email            String   @unique
  passwordHash     String
  firstName        String?
  lastName         String?
  phone            String?
  acceptTerms      Boolean  @default(false)
  marketingConsent Boolean  @default(false)
  ageConfirmed     Boolean  @default(false)
  isBlocked        Boolean  @default(false)
  orders           Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  addresses            CustomerAddress[]
  wishlist             Wishlist?
  contactConversations ContactConversation[]
  emailPreferences     EmailPreference?
  emailJobs            EmailJob[]
}

model CustomerAddress {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId        String   @db.ObjectId
  firstName         String
  lastName          String
  company           String?
  addressLine1      String
  addressLine2      String?
  city              String
  state             String
  postalCode        String
  country           String
  isDefaultShipping Boolean  @default(false)
  isDefaultBilling  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([customerId])
}

model ShippingMethod {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  price         Float
  estimatedDays String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Coupon {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  code          String    @unique
  discountType  String // 'PERCENTAGE' or 'FIXED'
  discountValue Float
  minOrderValue Float?
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  usageLimit    Int?
  usageCount    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum OrderStatus {
  PENDING
  PROCESSING
  PAID
  DELIVERED
  FAILED
  CANCELLED
  EXPIRED
  REFUNDED
}

model PaymentGateway {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String   @unique
  merchantId String?
  publicKey  String?
  secretKey  String?
  isActive   Boolean  @default(false)
  isTestMode Boolean  @default(true)
  updatedAt  DateTime @updatedAt
}

model Order {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber     String      @unique
  secureToken     String      @unique @default(cuid())
  customerId      String?     @db.ObjectId
  customerEmail   String
  totalAmount     Float
  currency        String      @default("CAD")
  status          OrderStatus @default(PENDING)
  paymentRef      String?     @unique
  shippingAddress Json?
  billingAddress  Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items OrderItem[]

  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  orderId    String  @db.ObjectId
  productId  String  @db.ObjectId
  variantId  String? @db.ObjectId
  title      String
  quantity   Int
  unitPrice  Float
  totalPrice Float

  order Order @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([orderId])
}

model Wishlist {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId String   @unique @db.ObjectId
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer       @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items    WishlistItem[]
}

model WishlistItem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  wishlistId String   @db.ObjectId
  productId  String   @db.ObjectId
  variantId  String?  @db.ObjectId
  createdAt  DateTime @default(now())

  wishlist Wishlist @relation(fields: [wishlistId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product  Product  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([wishlistId, productId, variantId])
  @@index([wishlistId])
}

enum ContactStatus {
  NEW
  OPEN
  AWAITING_CUSTOMER
  AWAITING_ADMIN
  RESOLVED
  CLOSED
  SPAM
}

enum ContactPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model ContactConversation {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  conversationId   String          @unique @default(cuid())
  customerId       String?         @db.ObjectId
  guestName        String?
  guestEmail       String?
  guestPhone       String?
  guestToken       String?         @unique
  category         String
  orderId          String?         @db.ObjectId
  subject          String
  status           ContactStatus   @default(NEW)
  priority         ContactPriority @default(NORMAL)
  assignedAdminId  String?         @db.ObjectId
  source           String          @default("WEB_FORM")
  isReadByAdmin    Boolean         @default(false)
  isReadByCustomer Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  lastReplyAt      DateTime?
  closedAt         DateTime?

  customer Customer?        @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages ContactMessage[]

  @@index([customerId])
  @@index([guestEmail])
  @@index([status])
}

model ContactMessage {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  conversationId   String    @db.ObjectId
  senderType       String // 'CUSTOMER', 'GUEST', or 'ADMIN'
  senderCustomerId String?   @db.ObjectId
  senderAdminId    String?   @db.ObjectId
  body             String
  attachment       String?
  createdAt        DateTime  @default(now())
  readAt           DateTime?

  conversation ContactConversation @relation(fields: [conversationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([conversationId])
}

model StoreSettings {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  storeName           String   @default("Rany.uk")
  storeDescription    String   @default("Your premium destination for the world's best products. Fast shipping, secure payments, and 24/7 support.")
  facebookUrl         String?
  twitterUrl          String?
  instagramUrl        String?
  taxEnabled          Boolean  @default(false)
  taxIncludedInPrices Boolean  @default(false)
  taxRate             Float    @default(0.0000)
  updatedAt           DateTime @updatedAt
}

model BlogPost {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String  @unique
  excerpt     String?
  content     String
  coverImage  String?
  isPublished Boolean @default(false)

  // AI & SEO Fields
  seoTitle           String?
  seoDescription     String?
  focusKeyword       String?
  secondaryKeywords  Json?
  faqs               Json?
  seoScore           Int     @default(0)
  generatedByAI      Boolean @default(false)
  aiGenerationStatus String?
  aiModel            String?
  sourceProductId    String? @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceProduct Product? @relation("ProductToBlog", fields: [sourceProductId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([isPublished])
  @@index([sourceProductId])
}

enum EmailChannel {
  TRANSACTIONAL
  MARKETING
  AUTOMATION
  ADMIN
}

enum EmailStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

model EmailPreference {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId        String   @unique @db.ObjectId
  topics            Json? // e.g., ["news", "promotions"]
  globalUnsubscribe Boolean  @default(false)
  isBounced         Boolean  @default(false)
  isSpamComplaint   Boolean  @default(false)
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model EmailTemplate {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  name      String       @unique
  subject   String
  htmlBody  String
  textBody  String?
  channel   EmailChannel @default(TRANSACTIONAL)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  jobs EmailJob[]
}

model EmailCampaign {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  subject     String
  status      EmailStatus @default(PENDING)
  scheduledAt DateTime?
  sentCount   Int         @default(0)
  failedCount Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  jobs EmailJob[]
}

model EmailJob {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  idempotencyKey String       @unique
  channel        EmailChannel @default(TRANSACTIONAL)
  status         EmailStatus  @default(PENDING)
  recipientEmail String
  customerId     String?      @db.ObjectId
  templateId     String?      @db.ObjectId
  campaignId     String?      @db.ObjectId
  payload        Json?

  attemptCount  Int       @default(0)
  maxAttempts   Int       @default(3)
  nextAttemptAt DateTime?

  providerMsgId String?
  errorLogs     Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sentAt    DateTime?

  customer Customer?      @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  template EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  campaign EmailCampaign? @relation(fields: [campaignId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status, nextAttemptAt])
  @@index([recipientEmail])
}

model CategoryCircle {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  image     String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
