{
  "name": "next-ecommerce-isr-starter",
  "version": "1.0.0",
  "private": true,
  "description": "Speed-first Next.js ecommerce starter with PostgreSQL, Redis, Meilisearch, importer, and ISR revalidation.",
  "scripts": {
    "dev": "next dev",
    "build": "rm -rf .next && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "worker:import": "tsx -r tsconfig-paths/register workers/product-import-worker.ts",
    "worker:email": "tsx -r tsconfig-paths/register workers/email-worker.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "^2.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "latest",
    "cloudinary": "^2.10.0",
    "csv-parse": "latest",
    "ioredis": "latest",
    "isomorphic-dompurify": "^3.18.0",
    "meilisearch": "latest",
    "next": "^15.5.19",
    "nodemailer": "^9.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "slugify": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^26.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "prisma": "^6.19.3",
    "tsconfig-paths": "latest",
    "tsx": "latest",
    "typescript": "^6.0.3"
  }
}
